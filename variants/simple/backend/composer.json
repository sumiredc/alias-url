{
  "name": "sumire/simple-alias-url",
  "description": "Simple alias URL service backend",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "Alias\\Simple\\": "src/"
    }
  },
  "require": {
    "slim/slim": "4.*",
    "slim/psr7": "^1.8",
    "php-di/php-di": "^7.1",
    "php": "~8.5.0",
    "vlucas/phpdotenv": "^5.6",
    "symfony/validator": "^8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.2",
    "pestphp/pest": "^4.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
